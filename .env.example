VITE_SITE_URL=https://presidentialdigs.com

# Optional: override where the frontend posts new leads.
# If not set, the app will call its own Vercel function at /api/leads.
VITE_LEAD_API_BASE_URL=

# Optional: social share image used by Seo component and meta tags.
# Should be an absolute URL to a hosted image.
VITE_SOCIAL_IMAGE_URL=https://presidentialdigs.com/social-share.jpg

# Optional: Google Analytics 4
VITE_GA_MEASUREMENT_ID=

# Optional: Google Tag Manager container ID
VITE_GTM_CONTAINER_ID=

